VITE_FIREBASE_API_KEY=your-firebase-api-key
# Fallback Google sign-in authDomain, used only on hosts that are NOT one of this
# project's Firebase domains (localhost/dev, or a non-Firebase deploy). When the
# app is served from a *.web.app / *.firebaseapp.com domain — or a custom domain
# listed in VITE_FIREBASE_APP_DOMAINS — the current host is used instead so the
# sign-in popup stays same-origin. See src/firebase.js -> resolveAuthDomain().
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Optional, comma-separated custom domains that serve this app AND Firebase's
# /__/auth/ helper (custom domains connected to this Hosting project). They must
# also be added under Firebase Authentication -> Settings -> Authorized domains.
VITE_FIREBASE_APP_DOMAINS=
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=
